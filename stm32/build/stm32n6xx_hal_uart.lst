1020:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** /** @defgroup UART_Exported_Functions_Group2 IO operation functions
1021:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****   * @brief UART Transmit/Receive functions
1022:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****   *
1023:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** @verbatim
1024:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****  ===============================================================================
1025:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****                       ##### IO operation functions #####
1026:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****  ===============================================================================
1027:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     [..]
1028:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     This subsection provides a set of functions allowing to manage the UART asynchronous
1029:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     and Half duplex data transfers.
1030:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1031:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) There are two modes of transfer:
1032:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****        (++) Blocking mode: The communication is performed in polling mode.
1033:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             The HAL status of all data processing is returned by the same function
1034:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             after finishing transfer.
1035:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****        (++) Non-Blocking mode: The communication is performed using Interrupts
1036:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             or DMA, These API's return the HAL status.
1037:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             The end of the data processing will be indicated through the
1038:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             dedicated UART IRQ when using Interrupt mode or the DMA IRQ when
1039:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             using DMA mode.
1040:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             The HAL_UART_TxCpltCallback(), HAL_UART_RxCpltCallback() user callbacks
1041:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             will be executed respectively at the end of the transmit or Receive process
1042:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             The HAL_UART_ErrorCallback()user callback will be executed when a communication error i
1043:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1044:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) Blocking mode API's are :
1045:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_Transmit()
1046:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_Receive()
1047:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
ARM GAS  /tmp/cc09BER3.s 			page 20


1048:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) Non-Blocking mode API's with Interrupt are :
1049:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_Transmit_IT()
1050:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_Receive_IT()
1051:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_IRQHandler()
1052:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1053:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) Non-Blocking mode API's with DMA are :
1054:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_Transmit_DMA()
1055:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_Receive_DMA()
1056:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_DMAPause()
1057:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_DMAResume()
1058:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_DMAStop()
1059:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1060:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) A set of Transfer Complete Callbacks are provided in Non_Blocking mode:
1061:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_TxHalfCpltCallback()
1062:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_TxCpltCallback()
1063:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_RxHalfCpltCallback()
1064:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_RxCpltCallback()
1065:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_ErrorCallback()
1066:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1067:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) Non-Blocking mode transfers could be aborted using Abort API's :
1068:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_Abort()
1069:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_AbortTransmit()
1070:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_AbortReceive()
1071:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_Abort_IT()
1072:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_AbortTransmit_IT()
1073:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_AbortReceive_IT()
1074:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1075:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) For Abort services based on interrupts (HAL_UART_Abortxxx_IT), a set of Abort Complete Call
1076:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_AbortCpltCallback()
1077:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_AbortTransmitCpltCallback()
1078:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UART_AbortReceiveCpltCallback()
1079:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1080:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) A Rx Event Reception Callback (Rx event notification) is available for Non_Blocking modes o
1081:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         reception services:
1082:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UARTEx_RxEventCallback()
1083:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1084:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) Wakeup from Stop mode Callback:
1085:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         (++) HAL_UARTEx_WakeupCallback()
1086:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1087:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     (#) In Non-Blocking mode transfers, possible errors are split into 2 categories.
1088:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         Errors are handled as follows :
1089:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****        (++) Error is considered as Recoverable and non blocking : Transfer could go till end, but e
1090:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             to be evaluated by user : this concerns Frame Error, Parity Error or Noise Error
1091:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             in Interrupt mode reception .
1092:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             Received character is then retrieved and stored in Rx buffer, Error code is set to allo
1093:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             to identify error type, and HAL_UART_ErrorCallback() user callback is executed.
1094:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             Transfer is kept ongoing on UART side.
1095:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             If user wants to abort it, Abort services should be called by user.
1096:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****        (++) Error is considered as Blocking : Transfer could not be completed properly and is abort
1097:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             This concerns Overrun Error In Interrupt mode reception and all errors in DMA mode.
1098:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             Error code is set to allow user to identify error type, and HAL_UART_ErrorCallback()
1099:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****             user callback is executed.
1100:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1101:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****     -@- In the Half duplex communication, it is forbidden to run the transmit
1102:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c ****         and receive process in parallel, the UART state HAL_UART_STATE_BUSY_TX_RX can't be useful.
1103:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** 
1104:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart.c **** @endverbatim
