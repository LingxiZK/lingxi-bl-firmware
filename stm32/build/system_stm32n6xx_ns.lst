 179:Core/Src/system_stm32n6xx_ns.c **** /**
 180:Core/Src/system_stm32n6xx_ns.c ****   * @brief  Update SystemCoreClock variable according to Clock Register Values.
 181:Core/Src/system_stm32n6xx_ns.c ****   *         The SystemCoreClock variable contains the core clock (HCLK), it can
 182:Core/Src/system_stm32n6xx_ns.c ****   *         be used by the user application to setup the SysTick timer or configure
 183:Core/Src/system_stm32n6xx_ns.c ****   *         other parameters.
 184:Core/Src/system_stm32n6xx_ns.c ****   *
 185:Core/Src/system_stm32n6xx_ns.c ****   * @note   From the non-secure application, the SystemCoreClock value is
 186:Core/Src/system_stm32n6xx_ns.c ****   *         retrieved from the secure domain via a Non-Secure Callable function
 187:Core/Src/system_stm32n6xx_ns.c ****   *         since the RCC peripheral may be protected with security attributes
 188:Core/Src/system_stm32n6xx_ns.c ****   *         that prevent to compute the SystemCoreClock variable from the RCC
 189:Core/Src/system_stm32n6xx_ns.c ****   *         peripheral registers.
 190:Core/Src/system_stm32n6xx_ns.c ****   *
 191:Core/Src/system_stm32n6xx_ns.c ****   * @note   Each time the core clock (HCLK) changes, this function must be called
 192:Core/Src/system_stm32n6xx_ns.c ****   *         to update SystemCoreClock variable value. Otherwise, any configuration
 193:Core/Src/system_stm32n6xx_ns.c ****   *         based on this variable will be incorrect.
 194:Core/Src/system_stm32n6xx_ns.c ****   *
 195:Core/Src/system_stm32n6xx_ns.c ****   * @note   - The system frequency computed by this function is not the real
 196:Core/Src/system_stm32n6xx_ns.c ****   *           frequency in the chip. It is calculated based on the predefined
 197:Core/Src/system_stm32n6xx_ns.c ****   *           constant and the selected clock source:
 198:Core/Src/system_stm32n6xx_ns.c ****   *
 199:Core/Src/system_stm32n6xx_ns.c ****   *           - If SYSCLK source is HSI, SystemCoreClock will contain the HSI_VALUE(*)
 200:Core/Src/system_stm32n6xx_ns.c ****   *
 201:Core/Src/system_stm32n6xx_ns.c ****   *           - If SYSCLK source is CSI, SystemCoreClock will contain the CSI_VALUE(**)
 202:Core/Src/system_stm32n6xx_ns.c ****   *
 203:Core/Src/system_stm32n6xx_ns.c ****   *           - If SYSCLK source is HSE, SystemCoreClock will contain the HSE_VALUE(***)
 204:Core/Src/system_stm32n6xx_ns.c ****   *
 205:Core/Src/system_stm32n6xx_ns.c ****   *           - If SYSCLK source is PLL, SystemCoreClock will contain the HSI_VALUE(*)
 206:Core/Src/system_stm32n6xx_ns.c ****   *             or CSI_VALUE(**) or HSE_VALUE(***) multiplied/divided by the PLL factors.
 207:Core/Src/system_stm32n6xx_ns.c ****   *
 208:Core/Src/system_stm32n6xx_ns.c ****   *         (*) HSI_VALUE is a constant defined in stm32n6xx_hal.h file (default value
 209:Core/Src/system_stm32n6xx_ns.c ****   *              64 MHz) but the real value may vary depending on the variations
 210:Core/Src/system_stm32n6xx_ns.c ****   *              in voltage and temperature.
 211:Core/Src/system_stm32n6xx_ns.c ****   *
 212:Core/Src/system_stm32n6xx_ns.c ****   *         (**) CSI_VALUE is a constant defined in stm32n6xx_hal.h file (default value
 213:Core/Src/system_stm32n6xx_ns.c ****   *             4 MHz) but the real value may vary depending on the variations
 214:Core/Src/system_stm32n6xx_ns.c ****   *             in voltage and temperature.
 215:Core/Src/system_stm32n6xx_ns.c ****   *
 216:Core/Src/system_stm32n6xx_ns.c ****   *         (***) HSE_VALUE is a constant defined in stm32n6xx_hal.h file (default value
 217:Core/Src/system_stm32n6xx_ns.c ****   *              16 MHz), user has to ensure that HSE_VALUE is same as the real
 218:Core/Src/system_stm32n6xx_ns.c ****   *              frequency of the crystal used. Otherwise, this function may
 219:Core/Src/system_stm32n6xx_ns.c ****   *              have wrong result.
 220:Core/Src/system_stm32n6xx_ns.c ****   *
 221:Core/Src/system_stm32n6xx_ns.c ****   *         - The result of this function could be not correct when using fractional
 222:Core/Src/system_stm32n6xx_ns.c ****   *           value for HSE crystal.
 223:Core/Src/system_stm32n6xx_ns.c ****   *
 224:Core/Src/system_stm32n6xx_ns.c ****   * @retval None
 225:Core/Src/system_stm32n6xx_ns.c ****   */
 226:Core/Src/system_stm32n6xx_ns.c **** void SystemCoreClockUpdate(void)
 227:Core/Src/system_stm32n6xx_ns.c **** {
  59              		.loc 1 227 1 view -0
  60              		.cfi_startproc
  61              		@ args = 0, pretend = 0, frame = 0
ARM GAS  /tmp/ccbc6gyF.s 			page 6


  62              		@ frame_needed = 0, uses_anonymous_args = 0
  63              		@ link register save eliminated.
 228:Core/Src/system_stm32n6xx_ns.c ****   /* Get the SystemCoreClock value from the secure domain */
 229:Core/Src/system_stm32n6xx_ns.c ****   /* Non-secure standalone: calculate SystemCoreClock directly */
 230:Core/Src/system_stm32n6xx_ns.c ****   SystemCoreClock = 64000000U;
  64              		.loc 1 230 3 view .LVU3
  65              		.loc 1 230 19 is_stmt 0 view .LVU4
  66 0000 014B     		ldr	r3, .L4
