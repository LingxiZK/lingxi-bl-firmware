 430:App/src/app_control.c **** /**
 431:App/src/app_control.c ****  * @brief  避障处理
ARM GAS  /tmp/ccmbqvzS.s 			page 17


 432:App/src/app_control.c ****  * @note   根据 ToF 距离 + 视觉检测，通过 PID 控制速度和航向
 433:App/src/app_control.c ****  */
 434:App/src/app_control.c **** static lingxi_err_t handle_obstacle_avoid(control_state_t *state,
 435:App/src/app_control.c ****                                           const npu_infer_result_t *infer,
 436:App/src/app_control.c ****                                           const sensor_fusion_data_t *sensor)
 437:App/src/app_control.c **** {
 438:App/src/app_control.c ****     float fused_dist = sensor->fused_distance_mm;
 439:App/src/app_control.c ****     uint32_t now = sensor->timestamp_ms;
 440:App/src/app_control.c **** 
 441:App/src/app_control.c ****     if (now == 0) now = HAL_GetTick();
 442:App/src/app_control.c **** 
 443:App/src/app_control.c ****     /* 安全距离值映射: 距离越近, 减速幅度越大 */
 444:App/src/app_control.c ****     float safe_dist_cmd = 0.0f;
 445:App/src/app_control.c **** 
 446:App/src/app_control.c ****     if (fused_dist < OBSTACLE_CRITICAL_DISTANCE_MM) {
 447:App/src/app_control.c ****         /* 临界距离: 全速后退 */
 448:App/src/app_control.c ****         safe_dist_cmd = -OBSTACLE_AVOID_SPEED_MMPS;
 449:App/src/app_control.c ****     } else if (fused_dist < OBSTACLE_WARNING_DISTANCE_MM) {
 450:App/src/app_control.c ****         /* 警告距离: 线性减速 + 转向 */
 451:App/src/app_control.c ****         float ratio = (fused_dist - OBSTACLE_CRITICAL_DISTANCE_MM) /
 452:App/src/app_control.c ****                       (OBSTACLE_WARNING_DISTANCE_MM - OBSTACLE_CRITICAL_DISTANCE_MM);
 453:App/src/app_control.c ****         safe_dist_cmd = -OBSTACLE_AVOID_SPEED_MMPS * (1.0f - ratio);
 454:App/src/app_control.c ****     } else if (fused_dist < OBSTACLE_SAFE_DISTANCE_MM) {
 455:App/src/app_control.c ****         /* 安全距离内: 缓慢接近 */
 456:App/src/app_control.c ****         safe_dist_cmd = OBSTACLE_AVOID_SPEED_MMPS * 0.3f;
 457:App/src/app_control.c ****     } else {
 458:App/src/app_control.c ****         /* 安全距离外: 正常巡航 */
 459:App/src/app_control.c ****         safe_dist_cmd = OBSTACLE_AVOID_SPEED_MMPS * 0.6f;
 460:App/src/app_control.c ****     }
 461:App/src/app_control.c **** 
 462:App/src/app_control.c ****     /* PID 速度控制 */
 463:App/src/app_control.c ****     float speed_raw = pid_update(&s_speed_pid, safe_dist_cmd,
 464:App/src/app_control.c ****                                  sensor->fused_distance_mm, now);
 465:App/src/app_control.c ****     float speed_smooth = pid_apply_slew(&s_speed_pid, speed_raw, now);
 466:App/src/app_control.c **** 
 467:App/src/app_control.c ****     /* 航向角偏差: 检测到障碍物的边沿方向 */
 468:App/src/app_control.c ****     float heading_error = 0.0f;
 469:App/src/app_control.c ****     if (infer->num_detections > 0) {
 470:App/src/app_control.c ****         /* 计算障碍物相对于图像中心的偏移 */
 471:App/src/app_control.c ****         float obj_center_x = (float)infer->detections[0].x +
 472:App/src/app_control.c ****                             (float)infer->detections[0].w / 2.0f;
 473:App/src/app_control.c ****         float image_center_x = NPU_INPUT_WIDTH / 2.0f;
 474:App/src/app_control.c ****         /* 偏移量映射到航向角 (简单比例) */
 475:App/src/app_control.c ****         heading_error = (obj_center_x - image_center_x) / image_center_x * 30.0f;
 476:App/src/app_control.c ****     }
 477:App/src/app_control.c **** 
 478:App/src/app_control.c ****     float yaw_raw = pid_update(&s_yaw_pid, heading_error, 0.0f, now);
 479:App/src/app_control.c ****     float yaw_smooth = pid_apply_slew(&s_yaw_pid, yaw_raw, now);
 480:App/src/app_control.c **** 
 481:App/src/app_control.c ****     /* 更新状态 */
 482:App/src/app_control.c ****     state->target_distance_mm = (uint16_t)(fused_dist);
 483:App/src/app_control.c ****     state->target_heading_deg = (int16_t)(yaw_smooth);
 484:App/src/app_control.c ****     state->target_speed_mmps = (int16_t)(speed_smooth);
 485:App/src/app_control.c ****     state->emergency_stop = 0;
 486:App/src/app_control.c **** 
 487:App/src/app_control.c ****     return LINGXI_OK;
 488:App/src/app_control.c **** }
ARM GAS  /tmp/ccmbqvzS.s 			page 18


