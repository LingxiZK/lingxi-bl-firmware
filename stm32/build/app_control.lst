  26:App/src/app_control.c **** /**
  27:App/src/app_control.c ****  * @brief PID 控制器实例
  28:App/src/app_control.c ****  */
  29:App/src/app_control.c **** typedef struct {
  30:App/src/app_control.c ****     /* 误差累积 */
  31:App/src/app_control.c ****     float integral;          /* 积分项 (受 anti-windup 保护) */
  32:App/src/app_control.c ****     float prev_error;        /* 上次误差 (用于微分) */
  33:App/src/app_control.c ****     float prev_output;       /* 上次输出 (用于前馈记忆) */
  34:App/src/app_control.c **** 
  35:App/src/app_control.c ****     /* 参数 */
  36:App/src/app_control.c ****     float Kp;                /* 比例增益 */
  37:App/src/app_control.c ****     float Ki;                /* 积分增益 */
  38:App/src/app_control.c ****     float Kd;                /* 微分增益 */
  39:App/src/app_control.c ****     float ff_gain;           /* 前馈增益 (feedforward) */
  40:App/src/app_control.c ****     float integral_limit;    /* 积分限幅 (anti-windup) */
  41:App/src/app_control.c ****     float output_limit;      /* 输出限幅 */
  42:App/src/app_control.c **** 
  43:App/src/app_control.c ****     /* 指令平滑 (Slew Rate Limiter) */
  44:App/src/app_control.c ****     float slew_rate;         /* 最大变化率 (单位/秒) */
  45:App/src/app_control.c ****     float last_slew_output;  /* 上次平滑后的输出 */
  46:App/src/app_control.c ****     uint32_t last_update_ms; /* 上次更新时间戳 */
  47:App/src/app_control.c **** 
  48:App/src/app_control.c ****     /* 统计 */
  49:App/src/app_control.c ****     uint32_t update_count;
  50:App/src/app_control.c **** } pid_ctrl_t;
  51:App/src/app_control.c **** 
  52:App/src/app_control.c **** /* =============================================================================
  53:App/src/app_control.c ****  * 私有变量
  54:App/src/app_control.c ****  * ==========================================================================*/
  55:App/src/app_control.c **** 
  56:App/src/app_control.c **** static uint8_t s_control_initialized = 0;
  57:App/src/app_control.c **** static control_state_t s_state = {0};
  58:App/src/app_control.c **** 
  59:App/src/app_control.c **** /* 三轴 PID 控制器 */
  60:App/src/app_control.c **** static pid_ctrl_t s_z_pid;      /* 高度/距离控制 (Z轴) */
  61:App/src/app_control.c **** static pid_ctrl_t s_yaw_pid;    /* 航向控制 (Yaw) */
  62:App/src/app_control.c **** static pid_ctrl_t s_speed_pid;  /* 水平速度控制 (X/Y) */
  63:App/src/app_control.c **** 
