 490:App/src/app_control.c **** /**
 491:App/src/app_control.c ****  * @brief  边缘识别处理
 492:App/src/app_control.c ****  * @note   检测到飞行平台边缘 (如桌面/楼顶边缘) 时, 保持悬停并发出警告
 493:App/src/app_control.c ****  */
 494:App/src/app_control.c **** static lingxi_err_t handle_edge_detect(control_state_t *state,
 495:App/src/app_control.c ****                                        const npu_infer_result_t *infer)
 496:App/src/app_control.c **** {
 497:App/src/app_control.c ****     uint32_t now = HAL_GetTick();
 498:App/src/app_control.c **** 
 499:App/src/app_control.c ****     /* 边缘检测: 立即制动, 保持悬停 */
 500:App/src/app_control.c ****     float speed_raw = pid_update(&s_speed_pid, 0.0f, 0.0f, now);
 501:App/src/app_control.c ****     float speed_smooth = pid_apply_slew(&s_speed_pid, speed_raw, now);
 502:App/src/app_control.c **** 
 503:App/src/app_control.c ****     /* 航向: 根据边缘在图像中的位置, 轻微转向 */
 504:App/src/app_control.c ****     float heading_target = 0.0f;
 505:App/src/app_control.c ****     if (infer->num_detections > 0) {
 506:App/src/app_control.c ****         float edge_center_x = (float)infer->detections[0].x +
 507:App/src/app_control.c ****                               (float)infer->detections[0].w / 2.0f;
 508:App/src/app_control.c ****         float image_center_x = NPU_INPUT_WIDTH / 2.0f;
 509:App/src/app_control.c ****         heading_target = (edge_center_x - image_center_x) / image_center_x * 45.0f;
 510:App/src/app_control.c ****     }
 511:App/src/app_control.c **** 
 512:App/src/app_control.c ****     float yaw_raw = pid_update(&s_yaw_pid, heading_target, 0.0f, now);
 513:App/src/app_control.c ****     float yaw_smooth = pid_apply_slew(&s_yaw_pid, yaw_raw, now);
 514:App/src/app_control.c **** 
 515:App/src/app_control.c ****     state->target_distance_mm = 0;
 516:App/src/app_control.c ****     state->target_heading_deg = (int16_t)(yaw_smooth);
 517:App/src/app_control.c ****     state->target_speed_mmps = (int16_t)(speed_smooth);
 518:App/src/app_control.c ****     state->emergency_stop = 0;
 519:App/src/app_control.c **** 
 520:App/src/app_control.c ****     return LINGXI_OK;
 521:App/src/app_control.c **** }
 522:App/src/app_control.c **** 
 523:App/src/app_control.c **** /**
 524:App/src/app_control.c ****  * @brief  目标跟踪处理
 525:App/src/app_control.c ****  * @note   根据 NPU 跟踪结果 (track_x, track_y) 生成跟踪指令
 526:App/src/app_control.c ****  */
 527:App/src/app_control.c **** static lingxi_err_t handle_track(control_state_t *state,
 528:App/src/app_control.c ****                                  const npu_infer_result_t *infer)
 529:App/src/app_control.c **** {
 530:App/src/app_control.c ****     uint32_t now = HAL_GetTick();
 531:App/src/app_control.c **** 
 532:App/src/app_control.c ****     /* 跟踪目标位置偏差 */
 533:App/src/app_control.c ****     float track_dx = infer->track_x - (NPU_INPUT_WIDTH / 2.0f);
 534:App/src/app_control.c ****     float track_dy = infer->track_y - (NPU_INPUT_HEIGHT / 2.0f);
 535:App/src/app_control.c ****     (void)(track_dy); /* 预留垂直偏差, 后续扩展使用 */
 536:App/src/app_control.c **** 
 537:App/src/app_control.c ****     /* 偏差映射到控制量 */
 538:App/src/app_control.c ****     float yaw_target = track_dx / (NPU_INPUT_WIDTH / 2.0f) * 30.0f;
 539:App/src/app_control.c **** 
 540:App/src/app_control.c ****     /* 根据目标大小估算距离 (目标越大越近) */
 541:App/src/app_control.c ****     float dist_estimation = 0.0f;
 542:App/src/app_control.c ****     if (infer->num_detections > 0) {
 543:App/src/app_control.c ****         float obj_area = (float)infer->detections[0].w * 
 544:App/src/app_control.c ****                          (float)infer->detections[0].h;
 545:App/src/app_control.c ****         float ref_area = (float)(NPU_INPUT_WIDTH/4) * (float)(NPU_INPUT_HEIGHT/4);
ARM GAS  /tmp/ccmbqvzS.s 			page 19


 546:App/src/app_control.c ****         if (obj_area > 0.0f) {
 547:App/src/app_control.c ****             dist_estimation = ref_area / obj_area * 1000.0f;
 548:App/src/app_control.c ****         }
 549:App/src/app_control.c ****     }
 550:App/src/app_control.c **** 
 551:App/src/app_control.c ****     /* PID 控制 */
 552:App/src/app_control.c ****     float yaw_raw = pid_update(&s_yaw_pid, yaw_target, 0.0f, now);
 553:App/src/app_control.c ****     float yaw_smooth = pid_apply_slew(&s_yaw_pid, yaw_raw, now);
 554:App/src/app_control.c **** 
 555:App/src/app_control.c ****     float speed_raw = pid_update(&s_speed_pid, dist_estimation, 0.0f, now);
 556:App/src/app_control.c ****     float speed_smooth = pid_apply_slew(&s_speed_pid, speed_raw, now);
 557:App/src/app_control.c **** 
 558:App/src/app_control.c ****     state->target_distance_mm = (uint16_t)(dist_estimation);
 559:App/src/app_control.c ****     state->target_heading_deg = (int16_t)(yaw_smooth);
 560:App/src/app_control.c ****     state->target_speed_mmps = (int16_t)(speed_smooth);
 561:App/src/app_control.c ****     state->emergency_stop = 0;
 562:App/src/app_control.c **** 
 563:App/src/app_control.c ****     return LINGXI_OK;
 564:App/src/app_control.c **** }
