  92:App/src/app_control.c **** /**
  93:App/src/app_control.c ****  * @brief  初始化主控逻辑模块
  94:App/src/app_control.c ****  */
  95:App/src/app_control.c **** lingxi_err_t app_control_init(void)
  96:App/src/app_control.c **** {
  97:App/src/app_control.c ****     memset(&s_state, 0, sizeof(control_state_t));
  98:App/src/app_control.c ****     s_state.current_mode = CTRL_MODE_IDLE;
  99:App/src/app_control.c ****     s_state.last_mode = CTRL_MODE_IDLE;
 100:App/src/app_control.c **** 
 101:App/src/app_control.c ****     /* 初始化三轴 PID 控制器 */
 102:App/src/app_control.c ****     /* Z轴 (高度/距离): 慢响应, 大阻尼 */
 103:App/src/app_control.c ****     pid_init(&s_z_pid,
 104:App/src/app_control.c ****              2.5f,     /* Kp */
 105:App/src/app_control.c ****              0.15f,    /* Ki */
 106:App/src/app_control.c ****              0.8f,     /* Kd */
 107:App/src/app_control.c ****              0.1f,     /* ff_gain */
 108:App/src/app_control.c ****              500.0f,   /* integral_limit */
 109:App/src/app_control.c ****              2000.0f,  /* output_limit (mm/s) */
 110:App/src/app_control.c ****              500.0f);  /* slew_rate (mm/s/s) */
 111:App/src/app_control.c **** 
 112:App/src/app_control.c ****     /* Yaw (航向): 快响应, 低阻尼 */
 113:App/src/app_control.c ****     pid_init(&s_yaw_pid,
 114:App/src/app_control.c ****              8.0f,     /* Kp */
 115:App/src/app_control.c ****              0.05f,    /* Ki */
 116:App/src/app_control.c ****              3.0f,     /* Kd */
 117:App/src/app_control.c ****              0.0f,     /* ff_gain */
 118:App/src/app_control.c ****              200.0f,   /* integral_limit */
 119:App/src/app_control.c ****              300.0f,   /* output_limit (deg/s) */
 120:App/src/app_control.c ****              180.0f);  /* slew_rate (deg/s/s) */
 121:App/src/app_control.c **** 
 122:App/src/app_control.c ****     /* 水平速度: 中等响应 */
 123:App/src/app_control.c ****     pid_init(&s_speed_pid,
 124:App/src/app_control.c ****              1.8f,     /* Kp */
 125:App/src/app_control.c ****              0.10f,    /* Ki */
 126:App/src/app_control.c ****              0.5f,     /* Kd */
 127:App/src/app_control.c ****              0.15f,    /* ff_gain */
 128:App/src/app_control.c ****              300.0f,   /* integral_limit */
 129:App/src/app_control.c ****              1000.0f,  /* output_limit (mm/s) */
 130:App/src/app_control.c ****              400.0f);  /* slew_rate (mm/s/s) */
 131:App/src/app_control.c **** 
 132:App/src/app_control.c ****     s_control_initialized = 1;
 133:App/src/app_control.c **** 
 134:App/src/app_control.c ****     LX_DEBUG_PRINT("Control module initialized (PID+FF+Slew)");
 135:App/src/app_control.c ****     return LINGXI_OK;
ARM GAS  /tmp/ccmbqvzS.s 			page 4


 136:App/src/app_control.c **** }
 137:App/src/app_control.c **** 
 138:App/src/app_control.c **** /**
 139:App/src/app_control.c ****  * @brief  更新控制逻辑 (主入口)
 140:App/src/app_control.c ****  * @note   由 vTaskControl 每 20ms (50Hz) 调用
 141:App/src/app_control.c ****  */
 142:App/src/app_control.c **** lingxi_err_t app_control_update(control_state_t *state,
 143:App/src/app_control.c ****                                 const npu_infer_result_t *infer_result,
 144:App/src/app_control.c ****                                 const sensor_fusion_data_t *sensor_data)
 145:App/src/app_control.c **** {
 146:App/src/app_control.c ****     LX_RETURN_IF_NULL(state);
 147:App/src/app_control.c ****     LX_RETURN_IF_NULL(infer_result);
 148:App/src/app_control.c ****     LX_RETURN_IF_NULL(sensor_data);
 149:App/src/app_control.c ****     if (!s_control_initialized) return LINGXI_ERR_NOT_INIT;
 150:App/src/app_control.c **** 
 151:App/src/app_control.c ****     uint32_t now = sensor_data->timestamp_ms;
 152:App/src/app_control.c ****     if (now == 0) {
 153:App/src/app_control.c ****         now = HAL_GetTick();
 154:App/src/app_control.c ****     }
 155:App/src/app_control.c **** 
 156:App/src/app_control.c ****     /* 更新内部状态 */
 157:App/src/app_control.c ****     s_state.last_update_ms = now;
 158:App/src/app_control.c **** 
 159:App/src/app_control.c ****     /* ================================================================
 160:App/src/app_control.c ****      * 模式选择与状态转移
 161:App/src/app_control.c ****      * ================================================================ */
 162:App/src/app_control.c **** 
 163:App/src/app_control.c ****     control_mode_t target_mode = s_state.current_mode;
 164:App/src/app_control.c **** 
 165:App/src/app_control.c ****     /* 1. 紧急停止优先级最高 */
 166:App/src/app_control.c ****     if (infer_result->obstacle_detected && 
 167:App/src/app_control.c ****         sensor_data->tof_valid && 
 168:App/src/app_control.c ****         sensor_data->tof_distance_mm < OBSTACLE_CRITICAL_DISTANCE_MM) {
 169:App/src/app_control.c ****         target_mode = CTRL_MODE_EMERGENCY;
 170:App/src/app_control.c ****     }
 171:App/src/app_control.c ****     /* 2. 避障 (有障碍物但未到临界距离) */
 172:App/src/app_control.c ****     else if (infer_result->obstacle_detected &&
 173:App/src/app_control.c ****              sensor_data->fused_distance_mm < OBSTACLE_SAFE_DISTANCE_MM) {
 174:App/src/app_control.c ****         target_mode = CTRL_MODE_OBSTACLE_AVOID;
 175:App/src/app_control.c ****     }
 176:App/src/app_control.c ****     /* 3. 边缘检测 */
 177:App/src/app_control.c ****     else if (infer_result->edge_detected) {
 178:App/src/app_control.c ****         target_mode = CTRL_MODE_EDGE_DETECT;
 179:App/src/app_control.c ****     }
 180:App/src/app_control.c ****     /* 4. 目标跟踪 */
 181:App/src/app_control.c ****     else if (infer_result->track_target_valid) {
 182:App/src/app_control.c ****         target_mode = CTRL_MODE_TRACK;
 183:App/src/app_control.c ****     }
 184:App/src/app_control.c ****     /* 5. 空闲 / 默认 */
 185:App/src/app_control.c ****     else {
 186:App/src/app_control.c ****         target_mode = CTRL_MODE_IDLE;
 187:App/src/app_control.c ****     }
 188:App/src/app_control.c **** 
 189:App/src/app_control.c ****     /* 执行模式切换 (带平滑过渡) */
 190:App/src/app_control.c ****     if (target_mode != s_state.current_mode) {
 191:App/src/app_control.c ****         smooth_mode_transition(&s_state, target_mode, now);
 192:App/src/app_control.c ****     }
ARM GAS  /tmp/ccmbqvzS.s 			page 5


 193:App/src/app_control.c **** 
 194:App/src/app_control.c ****     /* ================================================================
 195:App/src/app_control.c ****      * 按当前模式执行控制逻辑
 196:App/src/app_control.c ****      * ================================================================ */
 197:App/src/app_control.c **** 
 198:App/src/app_control.c ****     lingxi_err_t err = LINGXI_OK;
 199:App/src/app_control.c **** 
 200:App/src/app_control.c ****     switch (s_state.current_mode) {
 201:App/src/app_control.c ****         case CTRL_MODE_EMERGENCY:
 202:App/src/app_control.c ****             handle_emergency(&s_state);
 203:App/src/app_control.c ****             break;
 204:App/src/app_control.c **** 
 205:App/src/app_control.c ****         case CTRL_MODE_OBSTACLE_AVOID:
 206:App/src/app_control.c ****             err = handle_obstacle_avoid(&s_state, infer_result, sensor_data);
 207:App/src/app_control.c ****             break;
 208:App/src/app_control.c **** 
 209:App/src/app_control.c ****         case CTRL_MODE_EDGE_DETECT:
 210:App/src/app_control.c ****             err = handle_edge_detect(&s_state, infer_result);
 211:App/src/app_control.c ****             break;
 212:App/src/app_control.c **** 
 213:App/src/app_control.c ****         case CTRL_MODE_TRACK:
 214:App/src/app_control.c ****             err = handle_track(&s_state, infer_result);
 215:App/src/app_control.c ****             break;
 216:App/src/app_control.c **** 
 217:App/src/app_control.c ****         case CTRL_MODE_IDLE:
 218:App/src/app_control.c ****         default:
 219:App/src/app_control.c ****             /* 空闲模式: 逐步减速到零 */
 220:App/src/app_control.c ****             s_state.target_distance_mm = 0;
 221:App/src/app_control.c ****             s_state.target_heading_deg = 0;
 222:App/src/app_control.c ****             s_state.target_speed_mmps = 0;
 223:App/src/app_control.c ****             break;
 224:App/src/app_control.c ****     }
 225:App/src/app_control.c **** 
 226:App/src/app_control.c ****     /* 复制状态到输出 */
 227:App/src/app_control.c ****     memcpy(state, &s_state, sizeof(control_state_t));
 228:App/src/app_control.c ****     *state = s_state;
 229:App/src/app_control.c **** 
 230:App/src/app_control.c ****     return err;
 231:App/src/app_control.c **** }
 232:App/src/app_control.c **** 
 233:App/src/app_control.c **** /**
 234:App/src/app_control.c ****  * @brief  避障决策
 235:App/src/app_control.c ****  */
 236:App/src/app_control.c **** lingxi_err_t app_control_obstacle_avoid(control_state_t *state,
 237:App/src/app_control.c ****                                          const npu_infer_result_t *infer_result,
 238:App/src/app_control.c ****                                          const sensor_fusion_data_t *sensor_data)
 239:App/src/app_control.c **** {
 240:App/src/app_control.c ****     LX_RETURN_IF_NULL(state);
 241:App/src/app_control.c ****     LX_RETURN_IF_NULL(infer_result);
 242:App/src/app_control.c ****     LX_RETURN_IF_NULL(sensor_data);
 243:App/src/app_control.c **** 
 244:App/src/app_control.c ****     smooth_mode_transition(&s_state, CTRL_MODE_OBSTACLE_AVOID, 
 245:App/src/app_control.c ****                           (sensor_data->timestamp_ms != 0) ? 
 246:App/src/app_control.c ****                            sensor_data->timestamp_ms : HAL_GetTick());
 247:App/src/app_control.c **** 
 248:App/src/app_control.c ****     lingxi_err_t err = handle_obstacle_avoid(&s_state, infer_result, sensor_data);
 249:App/src/app_control.c ****     *state = s_state;
ARM GAS  /tmp/ccmbqvzS.s 			page 6


 250:App/src/app_control.c ****     return err;
 251:App/src/app_control.c **** }
 252:App/src/app_control.c **** 
 253:App/src/app_control.c **** /**
 254:App/src/app_control.c ****  * @brief  边缘识别决策
 255:App/src/app_control.c ****  */
 256:App/src/app_control.c **** lingxi_err_t app_control_edge_detect(control_state_t *state,
 257:App/src/app_control.c ****                                      const npu_infer_result_t *infer_result)
 258:App/src/app_control.c **** {
 259:App/src/app_control.c ****     LX_RETURN_IF_NULL(state);
 260:App/src/app_control.c ****     LX_RETURN_IF_NULL(infer_result);
 261:App/src/app_control.c **** 
 262:App/src/app_control.c ****     smooth_mode_transition(&s_state, CTRL_MODE_EDGE_DETECT,
 263:App/src/app_control.c ****                           HAL_GetTick());
 264:App/src/app_control.c **** 
 265:App/src/app_control.c ****     lingxi_err_t err = handle_edge_detect(&s_state, infer_result);
 266:App/src/app_control.c ****     *state = s_state;
 267:App/src/app_control.c ****     return err;
 268:App/src/app_control.c **** }
