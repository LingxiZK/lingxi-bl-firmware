 158:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c **** 
 159:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c **** /**
 160:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   * @brief  Enable the SPI slave mode.
 161:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   * @note When the USART operates in SPI slave mode, it handles data flow using
 162:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   *       the serial interface clock derived from the external SCLK signal
 163:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   *       provided by the external master SPI device.
 164:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   * @note In SPI slave mode, the USART must be enabled before starting the master
 165:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   *       communications (or between frames while the clock is stable). Otherwise,
 166:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   *       if the USART slave is enabled while the master is in the middle of a
 167:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   *       frame, it will become desynchronized with the master.
 168:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   * @note The data register of the slave needs to be ready before the first edge
 169:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   *       of the communication clock or before the end of the ongoing communication,
 170:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   *       otherwise the SPI slave will transmit zeros.
 171:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   * @param husart      USART handle.
 172:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   * @retval HAL status
 173:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c ****   */
 174:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_usart_ex.c **** HAL_StatusTypeDef HAL_USARTEx_EnableSlaveMode(USART_HandleTypeDef *husart)
