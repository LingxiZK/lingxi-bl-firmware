 197:App/src/app_fusion.c **** /* è¾…هٹ©: 6x6 çں©éکµن¹کو³• C = A * B */
 198:App/src/app_fusion.c **** static inline void mat_mul_6x6(const float A[6][6], const float B[6][6], float C[6][6])
 199:App/src/app_fusion.c **** {
 200:App/src/app_fusion.c ****     for (int i = 0; i < 6; i++) {
 201:App/src/app_fusion.c ****         for (int j = 0; j < 6; j++) {
 202:App/src/app_fusion.c ****             float sum = 0.0f;
 203:App/src/app_fusion.c ****             for (int k = 0; k < 6; k++) {
 204:App/src/app_fusion.c ****                 sum += A[i][k] * B[k][j];
 205:App/src/app_fusion.c ****             }
 206:App/src/app_fusion.c ****             C[i][j] = sum;
 207:App/src/app_fusion.c ****         }
 208:App/src/app_fusion.c ****     }
 209:App/src/app_fusion.c **** }
 210:App/src/app_fusion.c **** 
 211:App/src/app_fusion.c **** /* è¾…هٹ©: 6x6 çں©éکµè½¬ç½® B = A^T */
 212:App/src/app_fusion.c **** static inline void mat_trans_6x6(const float A[6][6], float B[6][6])
 213:App/src/app_fusion.c **** {
 214:App/src/app_fusion.c ****     for (int i = 0; i < 6; i++) {
 215:App/src/app_fusion.c ****         for (int j = 0; j < 6; j++) {
