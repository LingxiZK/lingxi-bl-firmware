 114:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_rcc_ex.c ****   *         SDMMC1, SDMMC2, SPDIFRX1, SPI1, SPI2, SPI3, SPI4, SPI5, SPI6, TIM,
