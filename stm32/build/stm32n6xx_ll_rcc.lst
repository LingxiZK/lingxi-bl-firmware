 143:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c **** 
 144:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c **** /**
 145:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   * @brief  Resets the RCC clock configuration to the default reset state.
 146:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   * @note   The default reset state of the clock configuration is given below:
 147:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   *            - HSI ON and used as system clock source
 148:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   *            - HSE, PLL1, PLL2 and PLL3 OFF
 149:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   *            - AHB, APB Bus pre-scaler set to 1.
 150:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   *            - CSS, MCO1 and MCO2 OFF
 151:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   *            - All interrupts disabled
 152:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   * @note   This function doesn't modify the configuration of the
 153:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   *            - Peripheral clocks
 154:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   *            - LSI, LSE and RTC clocks
 155:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   * @retval None
 156:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   */
 157:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c **** void LL_RCC_DeInit(void)
 158:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c **** {
 159:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   /* Disable all interrupts except default one */
 160:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_ll_rcc.c ****   WRITE_REG(RCC->CIER, RCC_CIER_HSECSSIE);
