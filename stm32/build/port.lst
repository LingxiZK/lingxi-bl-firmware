1563:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****     {
1564:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         volatile uint32_t ulOriginalPriority;
1565:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         volatile uint32_t ulImplementedPrioBits = 0;
1566:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         volatile uint8_t ucMaxPriorityValue;
1567:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1568:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Determine the maximum priority from which ISR safe FreeRTOS API
1569:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * functions can be called.  ISR safe functions are those that end in
1570:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * "FromISR".  FreeRTOS maintains separate thread and ISR API functions to
1571:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * ensure interrupt entry is as fast and simple as possible.
1572:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          *
1573:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * Save the interrupt priority value that is about to be clobbered. */
1574:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         ulOriginalPriority = portNVIC_SHPR2_REG;
1575:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1576:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Determine the number of priority bits available.  First write to all
1577:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * possible bits. */
1578:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         portNVIC_SHPR2_REG = 0xFF000000;
1579:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1580:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Read the value back to see how many bits stuck. */
1581:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         ucMaxPriorityValue = ( uint8_t ) ( ( portNVIC_SHPR2_REG & 0xFF000000 ) >> 24 );
1582:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1583:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Use the same mask on the maximum system call priority. */
1584:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         ucMaxSysCallPriority = configMAX_SYSCALL_INTERRUPT_PRIORITY & ucMaxPriorityValue;
1585:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1586:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Check that the maximum system call priority is nonzero after
1587:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * accounting for the number of priority bits supported by the
1588:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * hardware. A priority of 0 is invalid because setting the BASEPRI
1589:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * register to 0 unmasks all interrupts, and interrupts with priority 0
1590:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * cannot be masked using BASEPRI.
1591:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * See https://www.FreeRTOS.org/RTOS-Cortex-M3-M4.html */
1592:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         configASSERT( ucMaxSysCallPriority );
1593:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1594:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Check that the bits not implemented in hardware are zero in
1595:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * configMAX_SYSCALL_INTERRUPT_PRIORITY. */
1596:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         configASSERT( ( configMAX_SYSCALL_INTERRUPT_PRIORITY & ( ~ucMaxPriorityValue ) ) == 0U );
1597:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
ARM GAS  /tmp/ccsdtNMg.s 			page 39


1598:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Calculate the maximum acceptable priority group value for the number
1599:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * of bits read back. */
1600:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1601:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         while( ( ucMaxPriorityValue & portTOP_BIT_OF_BYTE ) == portTOP_BIT_OF_BYTE )
1602:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         {
1603:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****             ulImplementedPrioBits++;
1604:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****             ucMaxPriorityValue <<= ( uint8_t ) 0x01;
1605:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         }
1606:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1607:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         if( ulImplementedPrioBits == 8 )
1608:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         {
1609:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****             /* When the hardware implements 8 priority bits, there is no way for
1610:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * the software to configure PRIGROUP to not have sub-priorities. As
1611:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * a result, the least significant bit is always used for sub-priority
1612:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * and there are 128 preemption priorities and 2 sub-priorities.
1613:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              *
1614:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * This may cause some confusion in some cases - for example, if
1615:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY is set to 5, both 5 and 4
1616:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * priority interrupts will be masked in Critical Sections as those
1617:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * are at the same preemption priority. This may appear confusing as
1618:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * 4 is higher (numerically lower) priority than
1619:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY and therefore, should not
1620:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * have been masked. Instead, if we set configMAX_SYSCALL_INTERRUPT_PRIORITY
1621:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * to 4, this confusion does not happen and the behaviour remains the same.
1622:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              *
1623:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * The following assert ensures that the sub-priority bit in the
1624:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY is clear to avoid the above mentioned
1625:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****              * confusion. */
1626:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****             configASSERT( ( configMAX_SYSCALL_INTERRUPT_PRIORITY & 0x1U ) == 0U );
1627:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****             ulMaxPRIGROUPValue = 0;
1628:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         }
1629:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         else
1630:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         {
1631:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****             ulMaxPRIGROUPValue = portMAX_PRIGROUP_BITS - ulImplementedPrioBits;
1632:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         }
1633:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1634:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Shift the priority group value back to its position within the AIRCR
1635:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * register. */
1636:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         ulMaxPRIGROUPValue <<= portPRIGROUP_SHIFT;
1637:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         ulMaxPRIGROUPValue &= portPRIORITY_GROUP_MASK;
1638:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
1639:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         /* Restore the clobbered interrupt priority register to its original
1640:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****          * value. */
1641:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****         portNVIC_SHPR2_REG = ulOriginalPriority;
1642:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****     }
1643:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****     #endif /* #if ( ( configASSERT_DEFINED == 1 ) && ( portHAS_BASEPRI == 1 ) ) */
1644:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
