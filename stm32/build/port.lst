  53:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** /**
  54:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  * The FreeRTOS Cortex M33 port can be configured to run on the Secure Side only
  55:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  * i.e. the processor boots as secure and never jumps to the non-secure side.
  56:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  * The Trust Zone support in the port must be disabled in order to run FreeRTOS
  57:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  * on the secure side. The following are the valid configuration seetings:
  58:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  *
  59:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  * 1. Run FreeRTOS on the Secure Side:
  60:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  *    configRUN_FREERTOS_SECURE_ONLY = 1 and configENABLE_TRUSTZONE = 0
  61:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  *
  62:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  * 2. Run FreeRTOS on the Non-Secure Side with Secure Side function call support:
  63:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  *    configRUN_FREERTOS_SECURE_ONLY = 0 and configENABLE_TRUSTZONE = 1
  64:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  *
  65:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  * 3. Run FreeRTOS on the Non-Secure Side only i.e. no Secure Side function call support:
  66:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  *    configRUN_FREERTOS_SECURE_ONLY = 0 and configENABLE_TRUSTZONE = 0
  67:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****  */
  68:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** #if ( ( configRUN_FREERTOS_SECURE_ONLY == 1 ) && ( configENABLE_TRUSTZONE == 1 ) )
  69:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c ****     #error TrustZone needs to be disabled in order to run FreeRTOS on the Secure Side.
  70:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** #endif
  71:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** /*-----------------------------------------------------------*/
  72:Middlewares/FreeRTOS/portable/GCC/ARM_CM55_NTZ/non_secure/port.c **** 
