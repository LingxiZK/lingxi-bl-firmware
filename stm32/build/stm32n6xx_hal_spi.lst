  60:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****       (#) The compilation flag USE_HAL_SPI_REGISTER_CALLBACKS when set to 1UL
  61:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****           allows the user to configure dynamically the driver callbacks.
  62:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****           Use Functions HAL_SPI_RegisterCallback() to register an interrupt callback.
  63:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c **** 
  64:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****           Function HAL_SPI_RegisterCallback() allows to register following callbacks:
  65:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) TxCpltCallback        : SPI Tx Completed callback
  66:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) RxCpltCallback        : SPI Rx Completed callback
  67:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) TxRxCpltCallback      : SPI TxRx Completed callback
  68:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) TxHalfCpltCallback    : SPI Tx Half Completed callback
  69:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) RxHalfCpltCallback    : SPI Rx Half Completed callback
  70:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) TxRxHalfCpltCallback  : SPI TxRx Half Completed callback
  71:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) ErrorCallback         : SPI Error callback
  72:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) AbortCpltCallback     : SPI Abort callback
  73:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) SuspendCallback       : SPI Suspend callback
  74:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) MspInitCallback       : SPI Msp Init callback
  75:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****             (++) MspDeInitCallback     : SPI Msp DeInit callback
  76:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****           This function takes as parameters the HAL peripheral handle, the Callback ID
  77:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c ****           and a pointer to the user callback function.
  78:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_spi.c **** 
