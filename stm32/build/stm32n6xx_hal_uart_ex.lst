 233:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart_ex.c ****   /* Set the Driver Enable assertion and deassertion times */
 234:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart_ex.c ****   temp = (AssertionTime << UART_CR1_DEAT_ADDRESS_LSB_POS);
 235:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart_ex.c ****   temp |= (DeassertionTime << UART_CR1_DEDT_ADDRESS_LSB_POS);
