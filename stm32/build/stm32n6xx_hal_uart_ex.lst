 242:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart_ex.c ****   return (UART_CheckIdleState(huart));
 243:Drivers/STM32N6xx_HAL_Driver/Src/stm32n6xx_hal_uart_ex.c **** }
