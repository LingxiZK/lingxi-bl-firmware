  65:Middlewares/FreeRTOS/source/event_groups.c **** /*
  66:Middlewares/FreeRTOS/source/event_groups.c ****  * Test the bits set in uxCurrentEventBits to see if the wait condition is met.
  67:Middlewares/FreeRTOS/source/event_groups.c ****  * The wait condition is defined by xWaitForAllBits.  If xWaitForAllBits is
  68:Middlewares/FreeRTOS/source/event_groups.c ****  * pdTRUE then the wait condition is met if all the bits set in uxBitsToWaitFor
  69:Middlewares/FreeRTOS/source/event_groups.c ****  * are also set in uxCurrentEventBits.  If xWaitForAllBits is pdFALSE then the
  70:Middlewares/FreeRTOS/source/event_groups.c ****  * wait condition is met if any of the bits set in uxBitsToWait for are also set
  71:Middlewares/FreeRTOS/source/event_groups.c ****  * in uxCurrentEventBits.
  72:Middlewares/FreeRTOS/source/event_groups.c ****  */
  73:Middlewares/FreeRTOS/source/event_groups.c **** static BaseType_t prvTestWaitCondition( const EventBits_t uxCurrentEventBits,
