  58:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** /* Block sizes must not get too small. */
  59:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** #define heapMINIMUM_BLOCK_SIZE    ( ( size_t ) ( xHeapStructSize << 1 ) )
  60:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** 
  61:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** /* Assumes 8bit bytes! */
  62:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** #define heapBITS_PER_BYTE         ( ( size_t ) 8 )
  63:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** 
  64:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** /* Max value that fits in a size_t type. */
  65:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** #define heapSIZE_MAX              ( ~( ( size_t ) 0 ) )
  66:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** 
  67:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** /* Check if multiplying a and b will result in overflow. */
