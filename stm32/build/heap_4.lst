 198:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****         /* Check the block size we are trying to allocate is not so large that the
 199:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****          * top bit is set.  The top bit of the block size member of the BlockLink_t
 200:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****          * structure is used to determine who owns the block - the application or
 201:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****          * the kernel, so it must be free. */
 202:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****         if( heapBLOCK_SIZE_IS_VALID( xWantedSize ) != 0 )
 203:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****         {
 204:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****             if( ( xWantedSize > 0 ) && ( xWantedSize <= xFreeBytesRemaining ) )
 205:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****             {
 206:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                 /* Traverse the list from the start (lowest address) block until
 207:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                  * one of adequate size is found. */
 208:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                 pxPreviousBlock = &xStart;
