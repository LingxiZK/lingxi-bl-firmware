 177:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                     }
 178:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                     else
 179:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                     {
 180:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                         xWantedSize = 0;
 181:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                     }
 182:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                 }
 183:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****                 else
