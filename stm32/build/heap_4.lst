  85:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** /* Allocate the memory for the heap. */
  86:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** #if ( configAPPLICATION_ALLOCATED_HEAP == 1 )
  87:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** 
  88:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** /* The application writer has already defined the array used for the RTOS
  89:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** * heap - probably so it can be placed in a special segment or address. */
