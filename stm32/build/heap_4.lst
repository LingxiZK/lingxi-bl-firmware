  95:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** /* Define the linked list structure.  This is used to link free blocks in order
  96:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****  * of their memory address. */
  97:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** typedef struct A_BLOCK_LINK
  98:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** {
  99:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     struct A_BLOCK_LINK * pxNextFreeBlock; /**< The next free block in the list. */
 100:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     size_t xBlockSize;                     /**< The size of the free block. */
 101:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** } BlockLink_t;
