 138:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** void * pvPortMalloc( size_t xWantedSize )
 139:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** {
 140:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     BlockLink_t * pxBlock;
 141:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     BlockLink_t * pxPreviousBlock;
 142:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     BlockLink_t * pxNewBlockLink;
 143:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     void * pvReturn = NULL;
 144:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     size_t xAdditionalRequiredSize;
 145:Middlewares/FreeRTOS/portable/MemMang/heap_4.c **** 
 146:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     vTaskSuspendAll();
 147:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****     {
 148:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****         /* If this is the first call to malloc then the heap will require
 149:Middlewares/FreeRTOS/portable/MemMang/heap_4.c ****          * initialisation to setup the list of free blocks. */
