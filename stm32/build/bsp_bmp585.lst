 231:App/src/bsp_bmp585.c **** static uint8_t bmp585_xfer_byte(uint8_t tx)
 232:App/src/bsp_bmp585.c **** {
 233:App/src/bsp_bmp585.c ****     uint8_t rx = 0;
 234:App/src/bsp_bmp585.c ****     HAL_SPI_TransmitReceive(&hbmp585_spi, &tx, &rx, 1, BMP585_SPI_TIMEOUT_MS);
