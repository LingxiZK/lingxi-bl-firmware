 238:App/src/bsp_bmp585.c **** static lingxi_err_t bmp585_read_reg(uint8_t reg, uint8_t *buf, uint16_t len)
 239:App/src/bsp_bmp585.c **** {
 240:App/src/bsp_bmp585.c ****     LX_RETURN_IF_NULL(buf);
 241:App/src/bsp_bmp585.c ****     if (len == 0) return LINGXI_OK;
 242:App/src/bsp_bmp585.c **** 
 243:App/src/bsp_bmp585.c ****     bmp585_cs_low();
 244:App/src/bsp_bmp585.c ****     bmp585_xfer_byte(reg | 0x80);  /* 读操作: bit7=1 */
 245:App/src/bsp_bmp585.c ****     for (uint16_t i = 0; i < len; i++) {
 246:App/src/bsp_bmp585.c ****         buf[i] = bmp585_xfer_byte(0x00);
 247:App/src/bsp_bmp585.c ****     }
 248:App/src/bsp_bmp585.c ****     bmp585_cs_high();
 249:App/src/bsp_bmp585.c ****     return LINGXI_OK;
