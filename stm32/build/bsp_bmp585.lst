 177:App/src/bsp_bmp585.c ****  */
 178:App/src/bsp_bmp585.c **** void bsp_bmp585_irq_handler(void)
 179:App/src/bsp_bmp585.c **** {
 180:App/src/bsp_bmp585.c ****     /* 可通知 FreeRTOS 任务进行数据读取 */
 181:App/src/bsp_bmp585.c ****     /* 清除中断标志在数据读取时自动完成 */
 182:App/src/bsp_bmp585.c **** }
 183:App/src/bsp_bmp585.c **** 
 184:App/src/bsp_bmp585.c **** /**
 185:App/src/bsp_bmp585.c ****  * @brief  检查数据就绪
 186:App/src/bsp_bmp585.c ****  */
 187:App/src/bsp_bmp585.c **** bool bsp_bmp585_is_data_ready(void)
 188:App/src/bsp_bmp585.c **** {
 189:App/src/bsp_bmp585.c ****     if (!s_bmp585_initialized) {
 190:App/src/bsp_bmp585.c ****         return false;
 191:App/src/bsp_bmp585.c ****     }
 192:App/src/bsp_bmp585.c ****     return (HAL_GPIO_ReadPin(BMP585_INT_GPIO_PORT, BMP585_INT_PIN) == GPIO_PIN_SET);
ARM GAS  /tmp/cceCTLHS.s 			page 5


