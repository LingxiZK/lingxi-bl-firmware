 216:App/src/bsp_bmp585.c ****     hbmp585_spi.Init.CRCPolynomial = 7;
 217:App/src/bsp_bmp585.c **** 
 218:App/src/bsp_bmp585.c ****     HAL_SPI_Init(&hbmp585_spi);
