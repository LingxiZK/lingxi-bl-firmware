  37:App/src/bsp_bmp585.c **** /**
  38:App/src/bsp_bmp585.c ****  * @brief  初始化 BMP585
  39:App/src/bsp_bmp585.c ****  */
  40:App/src/bsp_bmp585.c **** lingxi_err_t bsp_bmp585_init(void)
  41:App/src/bsp_bmp585.c **** {
  42:App/src/bsp_bmp585.c ****     uint8_t chip_id = 0;
  43:App/src/bsp_bmp585.c ****     uint8_t buf[2];
  44:App/src/bsp_bmp585.c **** 
  45:App/src/bsp_bmp585.c ****     /* SPI 初始化 */
  46:App/src/bsp_bmp585.c ****     bmp585_spi_init();
  47:App/src/bsp_bmp585.c **** 
  48:App/src/bsp_bmp585.c ****     /* 读取 Chip ID */
  49:App/src/bsp_bmp585.c ****     if (bsp_bmp585_read_chip_id(&chip_id) != LINGXI_OK) {
  50:App/src/bsp_bmp585.c ****         LX_ERR_PRINT("BMP585 read chip ID failed");
  51:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
  52:App/src/bsp_bmp585.c ****     }
  53:App/src/bsp_bmp585.c ****     if (chip_id != BMP585_CHIP_ID) {
  54:App/src/bsp_bmp585.c ****         LX_ERR_PRINT("BMP585 chip ID mismatch: expected 0x%02X, got 0x%02X",
  55:App/src/bsp_bmp585.c ****                      BMP585_CHIP_ID, chip_id);
  56:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
  57:App/src/bsp_bmp585.c ****     }
  58:App/src/bsp_bmp585.c **** 
  59:App/src/bsp_bmp585.c ****     /* 软复位 */
  60:App/src/bsp_bmp585.c ****     if (bsp_bmp585_soft_reset() != LINGXI_OK) {
  61:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
  62:App/src/bsp_bmp585.c ****     }
  63:App/src/bsp_bmp585.c **** 
  64:App/src/bsp_bmp585.c ****     /* 配置 OSR: 气压 x8, 温度 x1 (平衡精度与功耗) */
  65:App/src/bsp_bmp585.c ****     buf[0] = 0x03;  /* osr_p=8, osr_t=1 */
  66:App/src/bsp_bmp585.c ****     if (bmp585_write_reg(BMP585_REG_OSR_CONFIG, buf, 1) != LINGXI_OK) {
  67:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
  68:App/src/bsp_bmp585.c ****     }
  69:App/src/bsp_bmp585.c **** 
  70:App/src/bsp_bmp585.c ****     /* 配置 ODR: 50 Hz */
  71:App/src/bsp_bmp585.c ****     buf[0] = 0x02;  /* odr=50Hz */
  72:App/src/bsp_bmp585.c ****     if (bmp585_write_reg(BMP585_REG_ODR_CONFIG, buf, 1) != LINGXI_OK) {
  73:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
  74:App/src/bsp_bmp585.c ****     }
  75:App/src/bsp_bmp585.c **** 
  76:App/src/bsp_bmp585.c ****     /* 配置 IIR 滤波: 气压 ×8, 温度 ×1 */
  77:App/src/bsp_bmp585.c ****     buf[0] = 0x03;  /* iir_p=3 (×8), iir_t=0 (×1) */
  78:App/src/bsp_bmp585.c ****     if (bmp585_write_reg(BMP585_REG_DSP_IIR, buf, 1) != LINGXI_OK) {
ARM GAS  /tmp/cceCTLHS.s 			page 3


  79:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
  80:App/src/bsp_bmp585.c ****     }
  81:App/src/bsp_bmp585.c **** 
  82:App/src/bsp_bmp585.c ****     /* 配置 INT: 数据就绪中断 */
  83:App/src/bsp_bmp585.c ****     buf[0] = 0x01;  /* drdy_en=1 */
  84:App/src/bsp_bmp585.c ****     if (bmp585_write_reg(BMP585_REG_INT_CONFIG, buf, 1) != LINGXI_OK) {
  85:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
  86:App/src/bsp_bmp585.c ****     }
  87:App/src/bsp_bmp585.c **** 
  88:App/src/bsp_bmp585.c ****     /* 进入正常模式 */
  89:App/src/bsp_bmp585.c ****     if (bsp_bmp585_set_mode(BMP585_MODE_NORMAL) != LINGXI_OK) {
  90:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
  91:App/src/bsp_bmp585.c ****     }
  92:App/src/bsp_bmp585.c **** 
  93:App/src/bsp_bmp585.c ****     s_bmp585_initialized = 1;
  94:App/src/bsp_bmp585.c ****     LX_DEBUG_PRINT("BMP585 initialized, chip_id=0x%02X", chip_id);
  95:App/src/bsp_bmp585.c ****     return LINGXI_OK;
  96:App/src/bsp_bmp585.c **** }
  97:App/src/bsp_bmp585.c **** 
  98:App/src/bsp_bmp585.c **** /**
  99:App/src/bsp_bmp585.c ****  * @brief  软复位
 100:App/src/bsp_bmp585.c ****  */
 101:App/src/bsp_bmp585.c **** lingxi_err_t bsp_bmp585_soft_reset(void)
 102:App/src/bsp_bmp585.c **** {
 103:App/src/bsp_bmp585.c ****     uint8_t cmd = 0xB6;
 104:App/src/bsp_bmp585.c ****     if (bmp585_write_reg(BMP585_REG_CMD, &cmd, 1) != LINGXI_OK) {
 105:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
 106:App/src/bsp_bmp585.c ****     }
 107:App/src/bsp_bmp585.c ****     HAL_Delay(2);  /* 等待复位完成 */
 108:App/src/bsp_bmp585.c ****     return LINGXI_OK;
 109:App/src/bsp_bmp585.c **** }
 110:App/src/bsp_bmp585.c **** 
 111:App/src/bsp_bmp585.c **** /**
 112:App/src/bsp_bmp585.c ****  * @brief  读取 Chip ID
 113:App/src/bsp_bmp585.c ****  */
 114:App/src/bsp_bmp585.c **** lingxi_err_t bsp_bmp585_read_chip_id(uint8_t *chip_id)
 115:App/src/bsp_bmp585.c **** {
 116:App/src/bsp_bmp585.c ****     LX_RETURN_IF_NULL(chip_id);
 117:App/src/bsp_bmp585.c ****     return bmp585_read_reg(BMP585_REG_CHIP_ID, chip_id, 1);
 118:App/src/bsp_bmp585.c **** }
 119:App/src/bsp_bmp585.c **** 
 120:App/src/bsp_bmp585.c **** /**
 121:App/src/bsp_bmp585.c ****  * @brief  设置测量模式
 122:App/src/bsp_bmp585.c ****  */
 123:App/src/bsp_bmp585.c **** lingxi_err_t bsp_bmp585_set_mode(uint8_t mode)
 124:App/src/bsp_bmp585.c **** {
 125:App/src/bsp_bmp585.c ****     uint8_t buf[1];
 126:App/src/bsp_bmp585.c ****     /* 读取当前 PWR_CTRL */
 127:App/src/bsp_bmp585.c ****     if (bmp585_read_reg(BMP585_REG_PWR_CTRL, buf, 1) != LINGXI_OK) {
 128:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
 129:App/src/bsp_bmp585.c ****     }
 130:App/src/bsp_bmp585.c ****     /* 清除 mode 位并设置新模式 */
 131:App/src/bsp_bmp585.c ****     buf[0] = (buf[0] & ~0x03) | (mode & 0x03);
 132:App/src/bsp_bmp585.c ****     if (bmp585_write_reg(BMP585_REG_PWR_CTRL, buf, 1) != LINGXI_OK) {
 133:App/src/bsp_bmp585.c ****         return LINGXI_ERR_SENSOR;
 134:App/src/bsp_bmp585.c ****     }
 135:App/src/bsp_bmp585.c ****     return LINGXI_OK;
ARM GAS  /tmp/cceCTLHS.s 			page 4


 136:App/src/bsp_bmp585.c **** }
 137:App/src/bsp_bmp585.c **** 
 138:App/src/bsp_bmp585.c **** /**
 139:App/src/bsp_bmp585.c ****  * @brief  读取压力和温度数据
 140:App/src/bsp_bmp585.c ****  */
 141:App/src/bsp_bmp585.c **** lingxi_err_t bsp_bmp585_read_data(bmp585_data_t *data)
 142:App/src/bsp_bmp585.c **** {
 143:App/src/bsp_bmp585.c ****     LX_RETURN_IF_NULL(data);
 144:App/src/bsp_bmp585.c **** 
 145:App/src/bsp_bmp585.c ****     if (!s_bmp585_initialized) {
 146:App/src/bsp_bmp585.c ****         return LINGXI_ERR_NOT_INIT;
 147:App/src/bsp_bmp585.c ****     }
 148:App/src/bsp_bmp585.c **** 
 149:App/src/bsp_bmp585.c ****     uint8_t raw[6];
 150:App/src/bsp_bmp585.c ****     if (bmp585_read_reg(BMP585_REG_PRESS_DATA_XLSB, raw, 6) != LINGXI_OK) {
 151:App/src/bsp_bmp585.c ****         return LINGXI_ERR_IO;
 152:App/src/bsp_bmp585.c ****     }
 153:App/src/bsp_bmp585.c **** 
 154:App/src/bsp_bmp585.c ****     /* 24-bit 压力数据 (有符号) */
 155:App/src/bsp_bmp585.c ****     int32_t press_raw = ((int32_t)raw[2] << 16) | ((int32_t)raw[1] << 8) | raw[0];
 156:App/src/bsp_bmp585.c ****     if (press_raw & 0x800000) {
 157:App/src/bsp_bmp585.c ****         press_raw |= 0xFF000000;
 158:App/src/bsp_bmp585.c ****     }
 159:App/src/bsp_bmp585.c **** 
 160:App/src/bsp_bmp585.c ****     /* 24-bit 温度数据 (有符号) */
 161:App/src/bsp_bmp585.c ****     int32_t temp_raw = ((int32_t)raw[5] << 16) | ((int32_t)raw[4] << 8) | raw[3];
 162:App/src/bsp_bmp585.c ****     if (temp_raw & 0x800000) {
 163:App/src/bsp_bmp585.c ****         temp_raw |= 0xFF000000;
 164:App/src/bsp_bmp585.c ****     }
 165:App/src/bsp_bmp585.c **** 
 166:App/src/bsp_bmp585.c ****     /* 转换为物理值 (简化: 假设默认校准参数) */
 167:App/src/bsp_bmp585.c ****     /* 气压: LSB / 2^16 * 100 hPa → 实际需要根据校准数据计算 */
 168:App/src/bsp_bmp585.c ****     data->pressure_hpa = (float)press_raw / 65536.0f * 100.0f;
 169:App/src/bsp_bmp585.c ****     data->temperature_c = (float)temp_raw / 65536.0f * 100.0f;
 170:App/src/bsp_bmp585.c ****     data->timestamp_ms = HAL_GetTick();
 171:App/src/bsp_bmp585.c **** 
 172:App/src/bsp_bmp585.c ****     return LINGXI_OK;
 173:App/src/bsp_bmp585.c **** }
 174:App/src/bsp_bmp585.c **** 
 175:App/src/bsp_bmp585.c **** /**
