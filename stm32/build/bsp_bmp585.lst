 212:App/src/bsp_bmp585.c ****     hbmp585_spi.Init.BaudRatePrescaler = SPI_BAUDRATEPRESCALER_8;  /* 200MHz/8 = 25MHz */
 213:App/src/bsp_bmp585.c ****     hbmp585_spi.Init.FirstBit = SPI_FIRSTBIT_MSB;
 214:App/src/bsp_bmp585.c ****     hbmp585_spi.Init.TIMode = SPI_TIMODE_DISABLE;
